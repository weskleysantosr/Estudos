# Copie para .env e preencha com valores reais.
# .env NUNCA é commitado (ver .gitignore). Em CI, os mesmos nomes viram
# GitHub Actions secrets (Settings > Secrets and variables > Actions).

# --- Databricks (ingestão / export) ---
# Host do workspace, sem barra final. Ex.: https://dbc-xxxxxxxx-xxxx.cloud.databricks.com
DATABRICKS_HOST=
# Personal Access Token com escopo mínimo necessário (só o workspace deste projeto).
# Gere em: User Settings > Developer > Access tokens. Defina um prazo de expiração curto e rotacione.
DATABRICKS_TOKEN=
# HTTP Path do SQL Warehouse (Compute > SQL Warehouses > seu warehouse > Connection details)
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxxxxxxxxxxxxx
DATABRICKS_CATALOG=digimon_lakehouse
DATABRICKS_SCHEMA_BRONZE=bronze
DATABRICKS_SCHEMA_SILVER=silver
DATABRICKS_SCHEMA_GOLD=gold

# --- Postgres serving DB (Neon/Supabase free tier) ---
# Usuário de ESCRITA — só o job de export usa (least privilege).
PG_WRITER_DSN=postgresql://writer_user:CHANGE_ME@host:5432/digimon?sslmode=require
# Usuário de LEITURA — a API usa este, nunca o writer (least privilege).
PG_READER_DSN=postgresql://reader_user:CHANGE_ME@host:5432/digimon?sslmode=require

# --- API (FastAPI) ---
# Origens permitidas por CORS, separadas por vírgula (domínio do site Streamlit em produção).
API_CORS_ORIGINS=http://localhost:8501
API_RATE_LIMIT_PER_MINUTE=60
API_CACHE_TTL_SECONDS=300

# --- Site (Streamlit) ---
SITE_API_BASE_URL=http://localhost:8000
